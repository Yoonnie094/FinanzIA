# =====================================================================
# INSTRUCCIONES IMPORTANTES ANTES DE EMPEZAR:
# Este archivo es solo un ejemplo (.env.example). Para que la aplicacion
# funcione en tu computadora, debes crear un nuevo archivo llamado:
# ".env.local" (o ".env") y copiar todo este contenido alli,
# rellenando las variables con tus propias credenciales.
# =====================================================================

# -------------------------------------------------------------
# Credenciales de Groq para la Inteligencia Artificial
# -------------------------------------------------------------
# Como obtenerla:
# 1. Ve a https://console.groq.com/keys
# 2. Inicia sesion o crea una cuenta
# 3. Haz clic en "Create API Key"
# 4. Copia la clave y pegala a continuacion:
GROQ_API_KEY=tu_api_key_de_groq_aqui


# -------------------------------------------------------------
# Credenciales de Supabase para la Base de Datos
# -------------------------------------------------------------
# Como obtenerlas:
# 1. Ve a https://supabase.com/dashboard y selecciona tu proyecto
# 2. En el menu izquierdo (hasta abajo), haz clic en "Project Settings" (icono de engranaje)
# 3. En el submenu, selecciona "API"
# 4. Copia el "Project URL" en la primera variable:
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_proyecto_supabase_aqui

# 5. Copia la clave etiquetada como "anon" / "public" en la segunda variable:
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui
